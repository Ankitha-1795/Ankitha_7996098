// =====================================================
// 4. Functions, Scope, Closures, Higher Order Functions
// =====================================================

function addEvent(event) {
    events.push(event);
}

function registerUser(eventId) {
    try {

        const event = events.find(
            e => e.id === eventId
        );

        if (!event) {
            throw new Error("Event not found");
        }

        if (event.seats <= 0) {
            throw new Error("No seats available");
        }

        event.seats--;

        registrationCounter();

        renderEvents();

        console.log(
            `Registered for ${event.name}`
        );

    } catch (error) {
        console.error(error.message);
    }
}

function filterEventsByCategory(category, callback) {

    const filteredEvents =
        category === "All"
            ? [...events]
            : events.filter(
                  event => event.category === category
              );

    callback(filteredEvents);
}

// Closure Example

function createRegistrationTracker() {

    let totalRegistrations = 0;

    return function () {

        totalRegistrations++;

        console.log(
            "Total Registrations:",
            totalRegistrations
        );

        return totalRegistrations;
    };
}

const registrationCounter =
    createRegistrationTracker();

// =====================================================
// 3. Conditionals, Loops and Error Handling
// =====================================================

function getValidEvents() {

    const validEvents = [];

    events.forEach(event => {

        if (
            event.upcoming &&
            event.seats > 0
        ) {
            validEvents.push(event);
        }

    });

    return validEvents;
}

// =====================================================
// 7. DOM Manipulation
// =====================================================

const eventContainer =
    document.querySelector("#eventContainer");

function renderEvents(eventList = getValidEvents()) {

    if (!eventContainer) return;

    eventContainer.innerHTML = "";

    eventList.forEach(event => {

        const card =
            document.createElement("div");

        card.classList.add("event-card");

        card.innerHTML = `
            <h3>${event.name}</h3>
            <p>Category: ${event.category}</p>
            <p>Location: ${event.location}</p>
            <p>Seats Left: ${event.seats}</p>

            <button class="register-btn"
                    data-id="${event.id}">
                Register
            </button>

            <button class="cancel-btn"
                    data-id="${event.id}">
                Cancel
            </button>
        `;

        eventContainer.appendChild(card);
    });

    attachButtonEvents();
}

// =====================================================
// 8. Event Handling
// =====================================================

function attachButtonEvents() {

    document
        .querySelectorAll(".register-btn")
        .forEach(button => {

            button.onclick = function () {

                registerUser(
                    Number(
                        this.dataset.id
                    )
                );

            };
        });

    document
        .querySelectorAll(".cancel-btn")
        .forEach(button => {

            button.onclick = function () {

                const event =
                    events.find(
                        e =>
                            e.id ===
                            Number(
                                this.dataset.id
                            )
                    );

                if (event) {

                    event.seats++;

                    renderEvents();
                }
            };
        });
}

const categoryFilter =
    document.querySelector(
        "#categoryFilter"
    );

if (categoryFilter) {

    categoryFilter.onchange =
        function () {

            filterEventsByCategory(
                this.value,
                renderEvents
            );

        };
}

const searchBox =
    document.querySelector("#searchBox");

if (searchBox) {

    searchBox.addEventListener(
        "keydown",
        () => {

            const keyword =
                searchBox.value.toLowerCase();

            const filtered =
                events.filter(event =>
                    event.name
                        .toLowerCase()
                        .includes(keyword)
                );

            renderEvents(filtered);
        }
    );
}

// =====================================================
// 9. Async JavaScript, Promises, Async/Await
// =====================================================

function fetchEventsPromise() {

    return new Promise((resolve) => {

        const spinner =
            document.querySelector("#spinner");

        if (spinner)
            spinner.style.display = "block";

        setTimeout(() => {

            resolve(events);

        }, 1500);
    });
}

fetchEventsPromise()
    .then(data => {

        console.log(
            "Promise Loaded:",
            data
        );

    })
    .catch(error => {

        console.error(error);

    });

async function loadEvents() {

    try {

        const spinner =
            document.querySelector("#spinner");

        if (spinner)
            spinner.style.display = "block";

        const data =
            await fetchEventsPromise();

        console.log(
            "Async Loaded:",
            data
        );

    } catch (error) {

        console.error(error);

    } finally {

        const spinner =
            document.querySelector("#spinner");

        if (spinner)
            spinner.style.display = "none";
    }
}

loadEvents();

