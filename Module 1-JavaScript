// =====================================================
// 5. Objects and Prototypes
// =====================================================

class Event {
    constructor(id, name, category, location, seats, upcoming = true) {
        this.id = id;
        this.name = name;
        this.category = category;
        this.location = location;
        this.seats = seats;
        this.upcoming = upcoming;
    }

    checkAvailability() {
        return this.seats > 0;
    }
}

