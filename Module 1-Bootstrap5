```html
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bootstrap 5 Exercises</title>

<!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
body{
    padding-bottom:70px;
}
.sidebar{
    min-height:200px;
}
.profile-img{
    width:150px;
    height:150px;
}
</style>
</head>
<body>

<!-- Exercise 10: Navbar -->
<nav class="navbar navbar-expand-lg navbar-dark bg-primary">
<div class="container">
<a class="navbar-brand" href="#">Bootstrap Portal</a>

<button class="navbar-toggler" type="button"
data-bs-toggle="collapse"
data-bs-target="#navbarNav">

<span class="navbar-toggler-icon"></span>

</button>

<div class="collapse navbar-collapse" id="navbarNav">

<ul class="navbar-nav me-auto">

<li class="nav-item">
<a class="nav-link active" href="#">Home</a>
</li>

<li class="nav-item">
<a class="nav-link" href="#">About</a>
</li>

<li class="nav-item">
<a class="nav-link" href="#">Contact</a>
</li>

</ul>

<form class="d-flex">
<input class="form-control me-2" type="search" placeholder="Search">
<button class="btn btn-light">Search</button>
</form>

</div>
</div>
</nav>

<!-- Typography -->
<div class="container mt-4">

<h1 class="display-1">Bootstrap 5</h1>

<p class="lead">
Lead paragraph example.
</p>

<p class="text-muted">
Muted text example.
</p>

<p class="fw-bold">
Bold text example.
</p>

<p class="text-uppercase">
uppercase text
</p>

<p class="text-lowercase">
LOWERCASE TEXT
</p>

<p class="text-capitalize">
bootstrap utilities example
</p>

</div>

<!-- Responsive Grid -->
<div class="container mt-5">

<h2>Responsive Grid</h2>

<div class="row">

<div class="col-12 col-md-6 col-lg-4 bg-primary text-white p-3">
Column 1
</div>

<div class="col-12 col-md-6 col-lg-4 bg-success text-white p-3">
Column 2
</div>

<div class="col-12 col-md-12 col-lg-4 bg-danger text-white p-3">
Column 3
</div>

</div>

</div>

<!-- Sidebar Layout -->
<div class="container mt-5">

<h2>Sidebar Layout</h2>

<div class="row">

<div class="col-md-3 bg-light sidebar p-3">
Sidebar
</div>

<div class="col-md-9 bg-secondary text-white p-3">
Content Area
</div>

</div>

</div>

<!-- Four Columns -->
<div class="container mt-5">

<div class="row">

<div class="col-sm-3 bg-warning p-3">1</div>
<div class="col-sm-3 bg-info p-3">2</div>
<div class="col-sm-3 bg-success p-3">3</div>
<div class="col-sm-3 bg-danger text-white p-3">4</div>

</div>

</div>

<!-- Alignment & Reordering -->
<div class="container mt-5">

<div class="row justify-content-center align-items-center"
style="height:200px;">

<div class="col-md-4 order-md-2 bg-warning p-3">
Order 2
</div>

<div class="col-md-4 order-md-1 bg-info p-3">
Order 1
</div>

</div>

</div>

<!-- Flexbox -->
<div class="container mt-5">

<div class="d-flex flex-column flex-md-row
justify-content-between align-items-center
border p-3">

<h4>Responsive Flexbox</h4>

<button class="btn btn-primary">
Action
</button>

</div>

</div>

<!-- Forms -->
<div class="container mt-5">

<h2>Registration Form</h2>

<form>

<div class="mb-3">
<input type="text"
class="form-control"
placeholder="Full Name">
</div>

<div class="input-group mb-3">

<span class="input-group-text">@</span>

<input type="email"
class="form-control"
placeholder="Email">

</div>

<div class="form-check">

<input class="form-check-input"
type="checkbox">

<label class="form-check-label">
Accept Terms
</label>

</div>

</form>

<h2 class="mt-4">
Login Form
</h2>

<div class="form-floating">

<input type="email"
class="form-control"
placeholder="Email">

<label>Email Address</label>

</div>

</div>

<!-- Buttons -->
<div class="container mt-5">

<h2>Buttons</h2>

<button class="btn btn-primary">Primary</button>
<button class="btn btn-secondary">Secondary</button>
<button class="btn btn-success">Success</button>
<button class="btn btn-danger">Danger</button>
<button class="btn btn-warning">Warning</button>

<button class="btn btn-outline-primary">
Outline Primary
</button>

<div class="btn-group mt-3">

<button class="btn btn-primary">Left</button>
<button class="btn btn-primary">Middle</button>
<button class="btn btn-primary">Right</button>

</div>

</div>

<!-- Nav Tabs & Pills -->
<div class="container mt-5">

<ul class="nav nav-tabs">

<li class="nav-item">
<a class="nav-link active" href="#">
Tab 1
</a>
</li>

<li class="nav-item">
<a class="nav-link" href="#">
Tab 2
</a>
</li>

</ul>

<ul class="nav nav-pills mt-3">

<li class="nav-item">
<a class="nav-link active" href="#">
Pill 1
</a>
</li>

<li class="nav-item">
<a class="nav-link" href="#">
Pill 2
</a>
</li>

</ul>

</div>

<!-- Card -->
<div class="container mt-5">

<div class="card shadow-lg rounded-pill">

<img
src="https://via.placeholder.com/400x200"
class="card-img-top"
alt="Profile">

<div class="card-body">

<h5 class="card-title">
John Doe
</h5>

<p class="card-text">
Profile Card Example
</p>

</div>

</div>

</div>

<!-- Media Layout -->
<div class="container mt-5">

<div class="d-flex">

<img
src="https://via.placeholder.com/100"
class="me-3 rounded">

<div>

<h5>Media Object</h5>

<p>
Image aligned to left of content.
</p>

</div>

</div>

</div>

<!-- Spacing -->
<div class="container mt-5 p-4 bg-light">

<h2 class="mb-4">
Pricing Plans
</h2>

<div class="row g-4">

<div class="col-md-4">
<div class="border p-4">
Basic Plan
</div>
</div>

<div class="col-md-4">
<div class="border p-4">
Standard Plan
</div>
</div>

<div class="col-md-4">
<div class="border p-4">
Premium Plan
</div>
</div>

</div>

</div>

<!-- Colors -->
<div class="container mt-5">

<div class="bg-primary text-white p-3 mb-2">
Primary
</div>

<div class="bg-warning p-3 mb-2">
Warning
</div>

<div class="bg-success text-white p-3 mb-2">
Success
</div>

<div class="bg-dark bg-gradient text-white p-3">
Dark Gradient
</div>

</div>

<!-- Display Utilities -->
<div class="container mt-5">

<div class="d-none d-md-block bg-info p-3">
Visible on Tablet+
</div>

<div class="d-none d-lg-flex bg-success text-white p-3 mt-2">
Visible on Large Screens
</div>

</div>

<!-- Borders -->
<div class="container mt-5 text-center">

<img
src="https://via.placeholder.com/150"
class="rounded-circle border border-primary border-3 profile-img">

</div>

<!-- Position Utilities -->
<div class="container mt-5">

<div class="position-relative d-inline-block">

<img
src="https://via.placeholder.com/200">

<span class="badge bg-danger
position-absolute
top-0
start-100
translate-middle">

New

</span>

</div>

</div>

<!-- Icons -->
<footer class="bg-dark text-white text-center p-4 mt-5">

<h4>Follow Us</h4>

<i class="bi bi-facebook fs-3 mx-2"></i>
<i class="bi bi-instagram fs-3 mx-2"></i>
<i class="bi bi-twitter-x fs-3 mx-2"></i>

<button class="btn btn-light ms-3">
<i class="bi bi-house"></i>
</button>

</footer>

<!-- Modal -->
<div class="container mt-5">

<button class="btn btn-primary"
data-bs-toggle="modal"
data-bs-target="#exampleModal">

Open Modal

</button>

</div>

<div class="modal fade"
id="exampleModal">

<div class="modal-dialog">

<div class="modal-content">

<div class="modal-header">

<h5 class="modal-title">
Bootstrap Modal
</h5>

<button
class="btn-close"
data-bs-dismiss="modal">
</button>

</div>

<div class="modal-body">
This is a modal popup.
</div>

</div>

</div>

</div>

<!-- Accordion -->
<div class="container mt-5">

<div class="accordion"
id="accordionExample">

<div class="accordion-item">

<h2 class="accordion-header">

<button
class="accordion-button"
data-bs-toggle="collapse"
data-bs-target="#collapseOne">

Question 1

</button>

</h2>

<div
id="collapseOne"
class="accordion-collapse collapse show">

<div class="accordion-body">
Answer 1
</div>

</div>

</div>

</div>

</div>

<!-- Fixed Footer -->
<div class="bg-dark text-white text-center p-2 position-fixed bottom-0 w-100">
Fixed Footer
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
```
