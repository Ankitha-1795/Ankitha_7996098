    // ==========================
    // 39 Reflection
    // ==========================
    static void reflectionDemo()
            throws Exception {

        Class<?> cls =
                Sample.class;

        Method[] methods =
                cls.getDeclaredMethods();

        for(Method m :
                methods) {

            System.out.println(
                    m.getName());
        }

        Object obj =
                cls.getDeclaredConstructor()
                        .newInstance();

        Method method =
                cls.getMethod(
                        "display");

        method.invoke(obj);
    }

    static class Sample {

        public void display() {

            System.out.println(
                    "Reflection Invoked");
