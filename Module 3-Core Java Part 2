    // ==========================
    // 36 HTTP Client
    // ==========================
    static void httpClientDemo()
            throws Exception {

        HttpClient client =
                HttpClient.newHttpClient();

        HttpRequest request =
                HttpRequest.newBuilder()
                        .uri(
                                URI.create(
                                        "https://api.github.com"))
                        .build();

        HttpResponse<String> response =
                client.send(
                        request,
                        HttpResponse.BodyHandlers.ofString());

        System.out.println(
                "Status: "
                        + response.statusCode());

        System.out.println(
                response.body()
                        .substring(
                                0,
                                200));
    }

