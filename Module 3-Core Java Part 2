    // ==========================
    // 35 TCP Server
    // ==========================
    static void tcpServer() {

        try {

            ServerSocket server =
                    new ServerSocket(5000);

            System.out.println(
                    "Server Waiting...");

            Socket socket =
                    server.accept();

            BufferedReader in =
                    new BufferedReader(
                            new InputStreamReader(
                                    socket.getInputStream()));

            System.out.println(
                    in.readLine());

            socket.close();
            server.close();

        } catch(Exception e) {

            System.out.println(e);
        }
    }

