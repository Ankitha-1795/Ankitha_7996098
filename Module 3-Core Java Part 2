    // ==========================
    // 40 Virtual Threads
    // ==========================
    static void virtualThreadDemo()
            throws Exception {

        for(int i=1;i<=100;i++) {

            Thread.startVirtualThread(
                    () -> {

                        System.out.println(
                                "Virtual Thread "
                                        + Thread.currentThread());
                    });
        }

        Thread.sleep(1000);
    }

    // ==========================
    // 41 Executor Callable
    // ==========================
    static void executorDemo()
            throws Exception {

        ExecutorService executor =
                Executors.newFixedThreadPool(3);

        Callable<Integer> task1 =
                () -> 10;

        Callable<Integer> task2 =
                () -> 20;

        Future<Integer> f1 =
                executor.submit(task1);

        Future<Integer> f2 =
                executor.submit(task2);

        System.out.println(
                "Result1 = "
                        + f1.get());

        System.out.println(
                "Result2 = "
                        + f2.get());

        executor.shutdown();
    }

    // ==========================
    // Pattern Matching Demo
    // ==========================
    static void patternDemo(
            Object obj) {

        switch(obj) {

            case Integer i ->
                    System.out.println(
                            "Integer "
                                    + i);

            case String s ->
                    System.out.println(
                            "String "
                                    + s);

            case Double d ->
                    System.out.println(
                            "Double "
                                    + d);

            default ->
                    System.out.println(
                            "Unknown");
        }
    }
