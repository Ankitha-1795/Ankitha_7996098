// Exercise 30
static void printType(Object obj) {

    switch(obj) {

        case Integer i ->
                System.out.println("Integer: " + i);

        case String s ->
                System.out.println("String: " + s);

        case Double d ->
                System.out.println("Double: " + d);

        default ->
                System.out.println("Unknown");
    }
}

static void patternMatchingDemo() {

