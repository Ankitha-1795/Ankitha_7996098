    // ==========================
    // Exercise 16 - Palindrome
    // ==========================
    static void palindromeChecker() {

        sc.nextLine();

        System.out.print("Enter String: ");

        String str = sc.nextLine();

        String cleaned =
                str.replaceAll(
                        "[^a-zA-Z0-9]",
                        "")
                        .toLowerCase();

        String reversed =
                new StringBuilder(cleaned)
                        .reverse()
                        .toString();

        if(cleaned.equals(reversed))
            System.out.println(
                    "Palindrome");
        else
            System.out.println(
                    "Not Palindrome");
    }
