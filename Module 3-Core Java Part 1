    // ==========================
    // Exercise 13 - Fibonacci
    // ==========================
    static int fibonacci(int n) {

        if(n <= 1)
            return n;

        return fibonacci(n - 1)
                + fibonacci(n - 2);
    }

    static void fibonacciDemo() {

        System.out.print("Enter n: ");
        int n = sc.nextInt();

        System.out.println(
                "Fibonacci = " + fibonacci(n));
